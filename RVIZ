----------  아래 코드 저장
import lgpio
import time

Motor_L1_Pin = 27
Motor_L2_Pin = 22
Motor_R1_Pin = 9
Motor_R2_Pin = 10

Enable_1 = 17
Enable_2 = 11

PWM_FREQ = 1000

h = lgpio.gpiochip_open(0)

for pin in [Motor_L1_Pin, Motor_L2_Pin, Motor_R1_Pin, Motor_R2_Pin]:
    lgpio.gpio_claim_output(h, pin)

for pin in [Enable_1, Enable_2]:
    lgpio.gpio_claim_output(h, pin)

def set_pwm(pin, duty_percent):
    duty_percent = max(0, min(100, duty_percent))
    duty = int(duty_percent * 10000)  # lgpio duty: 0~1000000 중 퍼센트 기반
    lgpio.tx_pwm(h, pin, PWM_FREQ, duty)

def stop():
    set_pwm(Enable_1, 0)
    set_pwm(Enable_2, 0)
    lgpio.gpio_write(h, Motor_L1_Pin, 0)
    lgpio.gpio_write(h, Motor_L2_Pin, 0)
    lgpio.gpio_write(h, Motor_R1_Pin, 0)
    lgpio.gpio_write(h, Motor_R2_Pin, 0)

def forward():
    set_pwm(Enable_1, 30)
    set_pwm(Enable_2, 30)
    lgpio.gpio_write(h, Motor_L1_Pin, 1)
    lgpio.gpio_write(h, Motor_L2_Pin, 0)
    lgpio.gpio_write(h, Motor_R1_Pin, 1)
    lgpio.gpio_write(h, Motor_R2_Pin, 0)

def reverse():
    set_pwm(Enable_1, 20)
    set_pwm(Enable_2, 20)
    lgpio.gpio_write(h, Motor_L1_Pin, 0)
    lgpio.gpio_write(h, Motor_L2_Pin, 1)
    lgpio.gpio_write(h, Motor_R1_Pin, 0)
    lgpio.gpio_write(h, Motor_R2_Pin, 1)

try:
    print("3초 전진")
    forward()
    time.sleep(3)

    print("1초 정지")
    stop()
    time.sleep(1)

    print("3초 후진")
    reverse()
    time.sleep(3)

    print("정지")
    stop()

except KeyboardInterrupt:
    stop()

finally:
    stop()
    lgpio.gpiochip_close(h)
    ----------
    저장하고 종료.
    Ctrl + O
    엔터
    Ctrl + X

이 파일은 ROS 없이 먼저 테스트한다
sudo python3 ~/motor_gpio_test.py

정상이면 
3초 전진
1초 정지
3초 후진
이게 되면 GPIO와 모터 배선은 정상이라고 볼 수 있어.

여기서 안 되면 ROS로 넘어가면 안 돼.
먼저 배선, 모터드라이버, 핀 번호를 다시 봐야 해.



