모터 제어 노드 코드
# motor_node.py
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist
import RPi.GPIO as GPIO

# 핀 설정 (네가 올린 그림 기준)
ENA = 11
IN1 = 9
IN2 = 10
IN3 = 22
IN4 = 27
ENB = 17

class MotorNode(Node):
    def __init__(self):
        super().__init__('motor_node')

        GPIO.setmode(GPIO.BCM)

        pins = [ENA, IN1, IN2, IN3, IN4, ENB]
        for pin in pins:
            GPIO.setup(pin, GPIO.OUT)

        self.pwm_left = GPIO.PWM(ENA, 100)
        self.pwm_right = GPIO.PWM(ENB, 100)

        self.pwm_left.start(0)
        self.pwm_right.start(0)

        self.create_subscription(Twist, '/cmd_vel', self.callback, 10)

    def callback(self, msg):
        linear = msg.linear.x
        angular = msg.angular.z

        left = linear - angular
        right = linear + angular

        # 속도 제한
        left = max(min(left, 1.0), -1.0)
        right = max(min(right, 1.0), -1.0)

        self.set_motor(left, right)

    def set_motor(self, left, right):
        # 왼쪽 모터
        if left > 0:
            GPIO.output(IN1, GPIO.HIGH)
            GPIO.output(IN2, GPIO.LOW)
        else:
            GPIO.output(IN1, GPIO.LOW)
            GPIO.output(IN2, GPIO.HIGH)

        # 오른쪽 모터
        if right > 0:
            GPIO.output(IN3, GPIO.HIGH)
            GPIO.output(IN4, GPIO.LOW)
        else:
            GPIO.output(IN3, GPIO.LOW)
            GPIO.output(IN4, GPIO.HIGH)

        self.pwm_left.ChangeDutyCycle(abs(left) * 100)
        self.pwm_right.ChangeDutyCycle(abs(right) * 100)


def main():
    rclpy.init()
    node = MotorNode()
    rclpy.spin(node)
    GPIO.cleanup()

if __name__ == '__main__':
    main()

