import lgpio
import time

# BCM 핀 번호
ENA = 11
IN1 = 9
IN2 = 10
IN3 = 22
IN4 = 27
ENB = 17

# PWM 설정
PWM_FREQ = 100
DUTY = 60  # 0~100

# gpiochip 열기
h = lgpio.gpiochip_open(0)

# 출력 핀 등록
pins = [ENA, IN1, IN2, IN3, IN4, ENB]
for pin in pins:
    lgpio.gpio_claim_output(h, pin)

def set_pwm(left_duty: float, right_duty: float) -> None:
    lgpio.tx_pwm(h, ENA, PWM_FREQ, left_duty)
    lgpio.tx_pwm(h, ENB, PWM_FREQ, right_duty)

def stop_pwm() -> None:
    lgpio.tx_pwm(h, ENA, 0, 0)
    lgpio.tx_pwm(h, ENB, 0, 0)

def stop_all() -> None:
    lgpio.gpio_write(h, IN1, 0)
    lgpio.gpio_write(h, IN2, 0)
    lgpio.gpio_write(h, IN3, 0)
    lgpio.gpio_write(h, IN4, 0)
    stop_pwm()

def left_forward(speed: float) -> None:
    lgpio.gpio_write(h, IN1, 1)
    lgpio.gpio_write(h, IN2, 0)
    lgpio.tx_pwm(h, ENA, PWM_FREQ, speed)

def left_backward(speed: float) -> None:
    lgpio.gpio_write(h, IN1, 0)
    lgpio.gpio_write(h, IN2, 1)
    lgpio.tx_pwm(h, ENA, PWM_FREQ, speed)

def right_forward(speed: float) -> None:
    lgpio.gpio_write(h, IN3, 1)
    lgpio.gpio_write(h, IN4, 0)
    lgpio.tx_pwm(h, ENB, PWM_FREQ, speed)

def right_backward(speed: float) -> None:
    lgpio.gpio_write(h, IN3, 0)
    lgpio.gpio_write(h, IN4, 1)
    lgpio.tx_pwm(h, ENB, PWM_FREQ, speed)

def both_forward(speed: float) -> None:
    lgpio.gpio_write(h, IN1, 1)
    lgpio.gpio_write(h, IN2, 0)
    lgpio.gpio_write(h, IN3, 1)
    lgpio.gpio_write(h, IN4, 0)
    set_pwm(speed, speed)

try:
    print("1. 왼쪽 모터 정방향 3초")
    left_forward(DUTY)
    time.sleep(3)
    stop_all()
    time.sleep(1)

    print("2. 왼쪽 모터 역방향 3초")
    left_backward(DUTY)
    time.sleep(3)
    stop_all()
    time.sleep(1)

    print("3. 오른쪽 모터 정방향 3초")
    right_forward(DUTY)
    time.sleep(3)
    stop_all()
    time.sleep(1)

    print("4. 오른쪽 모터 역방향 3초")
    right_backward(DUTY)
    time.sleep(3)
    stop_all()
    time.sleep(1)

    print("5. 양쪽 모터 전진 3초")
    both_forward(DUTY)
    time.sleep(3)
    stop_all()
    time.sleep(1)

    print("테스트 종료")

except KeyboardInterrupt:
    print("중단됨")

finally:
    stop_all()
    lgpio.gpiochip_close(h)

