import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist
import RPi.GPIO as GPIO

# 핀 설정 (네가 올린 그림 기준)
import RPi.GPIO as GPIO
import time

# BCM 핀 번호
ENA = 11
IN1 = 9
IN2 = 10
IN3 = 22
IN4 = 27
ENB = 17

GPIO.setmode(GPIO.BCM)
GPIO.setwarnings(False)

pins = [ENA, IN1, IN2, IN3, IN4, ENB]
for pin in pins:
    GPIO.setup(pin, GPIO.OUT)

pwm_left = GPIO.PWM(ENA, 100)
pwm_right = GPIO.PWM(ENB, 100)

pwm_left.start(0)
pwm_right.start(0)

def stop_all():
    GPIO.output(IN1, GPIO.LOW)
    GPIO.output(IN2, GPIO.LOW)
    GPIO.output(IN3, GPIO.LOW)
    GPIO.output(IN4, GPIO.LOW)
    pwm_left.ChangeDutyCycle(0)
    pwm_right.ChangeDutyCycle(0)

try:
    print("1. 왼쪽 모터 정방향 3초")
    GPIO.output(IN1, GPIO.HIGH)
    GPIO.output(IN2, GPIO.LOW)
    pwm_left.ChangeDutyCycle(60)
    time.sleep(3)
    stop_all()
    time.sleep(1)

    print("2. 왼쪽 모터 역방향 3초")
    GPIO.output(IN1, GPIO.LOW)
    GPIO.output(IN2, GPIO.HIGH)
    pwm_left.ChangeDutyCycle(60)
    time.sleep(3)
    stop_all()
    time.sleep(1)

    print("3. 오른쪽 모터 정방향 3초")
    GPIO.output(IN3, GPIO.HIGH)
    GPIO.output(IN4, GPIO.LOW)
    pwm_right.ChangeDutyCycle(60)
    time.sleep(3)
    stop_all()
    time.sleep(1)

    print("4. 오른쪽 모터 역방향 3초")
    GPIO.output(IN3, GPIO.LOW)
    GPIO.output(IN4, GPIO.HIGH)
    pwm_right.ChangeDutyCycle(60)
    time.sleep(3)
    stop_all()
    time.sleep(1)

    print("5. 양쪽 모터 전진 3초")
    GPIO.output(IN1, GPIO.HIGH)
    GPIO.output(IN2, GPIO.LOW)
    GPIO.output(IN3, GPIO.HIGH)
    GPIO.output(IN4, GPIO.LOW)
    pwm_left.ChangeDutyCycle(60)
    pwm_right.ChangeDutyCycle(60)
    time.sleep(3)
    stop_all()
    time.sleep(1)

    print("테스트 종료")

except KeyboardInterrupt:
    print("중단됨")

finally:
    stop_all()
    pwm_left.stop()
    pwm_right.stop()
    GPIO.cleanup()
