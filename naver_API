2단계: 코드

pythonimport requests
import json

CLIENT_ID = "여기에_Client_ID"
CLIENT_SECRET = "여기에_Client_Secret"

def search_shopping(query, display=10):
    url = "https://openapi.naver.com/v1/search/shop.json"
    headers = {
        "X-Naver-Client-Id": CLIENT_ID,
        "X-Naver-Client-Secret": CLIENT_SECRET
    }
    params = {
        "query": query,      # 검색어
        "display": display,  # 결과 수 (최대 100)
        "sort": "sim"        # sim=정확도, date=날짜, asc=가격낮은순, dsc=가격높은순
    }
    response = requests.get(url, headers=headers, params=params)
    
    if response.status_code != 200:
        print(f"에러 발생: {response.status_code}")
        print(response.text)
        return
    
    items = response.json()["items"]
    for i, item in enumerate(items, 1):
        # 제목에 포함된 <b> 태그 제거
        title = item["title"].replace("<b>", "").replace("</b>", "")
        print(f"{i}. {title}")
        print(f"   최저가: {int(item['lprice']):,}원")
        print(f"   쇼핑몰: {item['mallName']}")
        print(f"   링크: {item['link']}")
        print()

if __name__ == "__main__":
    query = input("검색어를 입력하세요: ")
    search_shopping(query, display=10)
