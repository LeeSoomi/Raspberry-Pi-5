# 웹페이지에 접속하기 위한 표준 라이브러리
import urllib.request

# 검색어를 URL에서 사용할 수 있는 형식으로 변환하기 위한 라이브러리
import urllib.parse

# 인터넷 접속 과정에서 발생하는 오류를 처리하기 위한 클래스
from urllib.error import HTTPError, URLError

# HTML 문서를 분석하기 위한 BeautifulSoup
from bs4 import BeautifulSoup


# 네이버 뉴스에서 검색할 단어
keyword = '롤게임전략'


# 검색 조건을 딕셔너리 형태로 작성
params = {
    'where': 'news',   # 뉴스 검색 사용
    'query': keyword   # 검색어 지정
}


# 검색 조건을 URL에서 사용할 수 있는 문자열로 변환
# 예: 롤게임전략 → URL 인코딩된 문자
query_string = urllib.parse.urlencode(params)


# 네이버 뉴스 검색 주소 생성
url = f'https://search.naver.com/search.naver?{query_string}'


# 네이버 서버에서 일반 웹브라우저의 접속으로 인식하도록 헤더 설정
headers = {
    # 라즈베리파이의 크롬 브라우저에서 접속한 것처럼 설정
    'User-Agent': (
        'Mozilla/5.0 (X11; Linux aarch64) '
        'AppleWebKit/537.36 (KHTML, like Gecko) '
        'Chrome/120.0.0.0 Safari/537.36'
    ),

    # 한국어 페이지를 우선 요청
    'Accept-Language': 'ko-KR,ko;q=0.9'
}


# 접속할 URL과 헤더 정보를 이용하여 요청 객체 생성
request = urllib.request.Request(
    url,
    headers=headers
)


try:
    # 네이버 뉴스 검색 페이지에 접속
    # timeout=10은 최대 10초 동안 응답을 기다린다는 의미
    with urllib.request.urlopen(request, timeout=10) as response:

        # 서버에서 받은 HTML 내용을 읽어오기
        html = response.read()


    # 가져온 HTML 문서를 BeautifulSoup으로 분석
    soup = BeautifulSoup(html, 'html.parser')


    # 뉴스 제목 링크에 해당하는 a 태그 검색
    # select()는 CSS 선택자를 이용하여 HTML 요소를 찾는 함수
    articles = soup.select(
        'a[data-heatmap-target=".tit"]'
    )


    # 뉴스 목록을 찾지 못했을 때 안내문 출력
    if not articles:
        print('뉴스 검색 결과를 찾지 못했습니다.')
        print('네이버 페이지 구조가 변경되었을 수 있습니다.')


    # 검색된 뉴스 기사들을 하나씩 반복
    for article in articles:

        # a 태그 안에 표시된 뉴스 제목 가져오기
        # strip=True는 제목 앞뒤의 불필요한 공백을 제거
        title = article.get_text(' ', strip=True)

        # a 태그의 href 속성에서 뉴스 기사 주소 가져오기
        link = article.get('href')


        # 뉴스 제목 출력
        print(title)

        # 뉴스 링크 출력
        print(link)

        # 기사별로 한 줄씩 띄워서 출력
        print()


# 서버에서 403, 404 등의 HTTP 오류가 발생한 경우
except HTTPError as error:
    print(f'HTTP 오류가 발생했습니다: {error.code}')


# 인터넷 연결 실패나 주소 접속 실패가 발생한 경우
except URLError as error:
    print(f'접속 오류가 발생했습니다: {error.reason}')


# 그 밖의 예상하지 못한 오류가 발생한 경우
except Exception as error:
    print(f'실행 오류가 발생했습니다: {error}')
